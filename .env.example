# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,debtclear.aryangorde.com

# Groq (primary AI — Llama 3.3 70B)
# Comma-separated keys enable the multi-key failover pool.
GROQ_API_KEYS=your-groq-key-1,your-groq-key-2
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude (optional fallback — used if Groq is unavailable)
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-6
